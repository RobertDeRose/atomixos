{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomixos.dev/schemas/config.schema.json",
  "title": "AtomixOS config.toml",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "users", "health", "containers"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1]
    },
    "users": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z_][a-z0-9_-]{0,31}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/userDefinition"
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dnsmasq": {
          "$ref": "#/$defs/dnsmasqDefinition"
        },
        "firewall": {
          "$ref": "#/$defs/firewallDefinition"
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "os_upgrade": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_url"],
      "properties": {
        "server_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "containers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container"],
      "properties": {
        "container": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/containerDefinition"
          }
        },
        "network": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/networkDefinition"
          }
        },
        "volume": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/volumeDefinition"
          }
        },
        "build": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/buildDefinition"
          }
        }
      }
    }
  },
  "$defs": {
    "userDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isAdmin": {
          "type": "boolean"
        },
        "ssh_key": {
          "type": "string"
        }
      }
    },
    "dnsmasqDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable": {
          "type": "boolean"
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "gateway_cidr": {
          "type": "string",
          "minLength": 1
        },
        "dhcp_start": {
          "type": "string",
          "minLength": 1
        },
        "dhcp_end": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "hostname_pattern": {
          "type": "string"
        },
        "gateway_aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "firewallDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inbound": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "wan": {
              "$ref": "#/$defs/portMap"
            },
            "lan": {
              "$ref": "#/$defs/portMap"
            }
          }
        }
      }
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "portList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port"
      }
    },
    "portMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tcp": {
          "$ref": "#/$defs/portList"
        },
        "udp": {
          "$ref": "#/$defs/portList"
        }
      }
    },
    "scalar": {
      "type": ["string", "integer", "boolean"]
    },
    "scalarOrScalarArray": {
      "type": ["string", "integer", "boolean", "array"],
      "items": {
        "$ref": "#/$defs/scalar"
      },
      "minItems": 1
    },
    "quadletSection": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalarOrScalarArray"
      }
    },
    "containerDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["privileged", "Container"],
      "properties": {
        "privileged": {
          "type": "boolean"
        },
        "Unit": {
          "$ref": "#/$defs/quadletSection"
        },
        "Container": {
          "$ref": "#/$defs/quadletSection"
        },
        "Install": {
          "$ref": "#/$defs/quadletSection"
        }
      }
    },
    "networkDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Network"],
      "properties": {
        "Network": {
          "$ref": "#/$defs/quadletSection"
        }
      }
    },
    "volumeDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Volume"],
      "properties": {
        "Volume": {
          "$ref": "#/$defs/quadletSection"
        }
      }
    },
    "buildDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Build"],
      "properties": {
        "Build": {
          "$ref": "#/$defs/quadletSection"
        }
      }
    }
  }
}
