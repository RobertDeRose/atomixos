#!/usr/bin/env bash
#MISE description="Flash image directly to eMMC block device (requires Linux + root)"
#MISE depends=["build"]
#USAGE flag "-y --yes" help="Skip confirmation prompt"
#USAGE flag "--ssh-key <key>" help="SSH public key (or path to .pub file) for admin user"
#USAGE arg "<emmc-device>" help="eMMC block device (e.g. /dev/mmcblk1)"
#USAGE arg "<uboot-dir>" help="Directory containing idbloader.img and u-boot.itb"
#USAGE arg "<kernel-image>" help="Path to kernel Image file"
#USAGE arg "<dtb-file>" help="Path to DTB file (e.g. rk3328-rock64.dtb)"
#USAGE arg "<squashfs-image>" help="Path to squashfs root filesystem image"
set -euo pipefail

# ── Platform check ─────────────────────────────────────────────────────────────

if [ "$(uname -s)" != "Linux" ]; then
	echo "ERROR: This task must run on Linux (requires block device access, mount, sfdisk)."
	echo "Run from inside a Linux VM (e.g. limactl shell) with the eMMC device attached."
	exit 1
fi

# ── Arguments ──────────────────────────────────────────────────────────────────

EMMC_DEV="${usage_emmc_device}"
UBOOT_DIR="${usage_uboot_dir}"
KERNEL_IMAGE="${usage_kernel_image}"
DTB_FILE="${usage_dtb_file}"
SQUASHFS_IMAGE="${usage_squashfs_image}"
SKIP_CONFIRM="${usage_yes:-false}"
SSH_KEY="${usage_ssh_key:-}"

# ── Partition layout (sizes in MiB) ───────────────────────────────────────────
#
# Offset     Size       Content
# 0          16 MiB     U-Boot (raw, idbloader @ sector 64, u-boot.itb @ sector 16384)
# 16 MiB     128 MiB    boot slot A (vfat) — kernel + DTB
# 144 MiB    128 MiB    boot slot B (vfat) — kernel + DTB
# 272 MiB    1024 MiB   rootfs slot A (squashfs)
# 1296 MiB   1024 MiB   rootfs slot B (squashfs)
# 2320 MiB   remaining  /persist (f2fs) — created by systemd-repart on first boot
#
# NOTE: The first partition MUST start at or after 16 MiB to avoid overwriting
# u-boot.itb which is written at sector 16384 (byte offset 8 MiB, ~9 MiB end).
#
# Note: the /persist partition is not created here. systemd-repart creates and
# formats it as f2fs on first boot, filling all remaining eMMC space.

BOOT_A_START_MIB=16
BOOT_A_SIZE_MIB=128
BOOT_B_START_MIB=144
BOOT_B_SIZE_MIB=128
ROOTFS_A_START_MIB=272
ROOTFS_A_SIZE_MIB=1024
ROOTFS_B_START_MIB=1296
ROOTFS_B_SIZE_MIB=1024

# ── Validation ─────────────────────────────────────────────────────────────────

log() { echo "[provision] $*"; }
die() {
	echo "[provision] ERROR: $*" >&2
	exit 1
}

[ "$(id -u)" -eq 0 ] || die "Must run as root"
[ -b "$EMMC_DEV" ] || die "Not a block device: $EMMC_DEV"
[ -d "$UBOOT_DIR" ] || die "Not a directory: $UBOOT_DIR"
[ -f "$UBOOT_DIR/idbloader.img" ] || die "Missing $UBOOT_DIR/idbloader.img"
[ -f "$UBOOT_DIR/u-boot.itb" ] || die "Missing $UBOOT_DIR/u-boot.itb"
[ -f "$KERNEL_IMAGE" ] || die "Missing kernel image: $KERNEL_IMAGE"
[ -f "$DTB_FILE" ] || die "Missing DTB: $DTB_FILE"
[ -f "$SQUASHFS_IMAGE" ] || die "Missing squashfs image: $SQUASHFS_IMAGE"

# Check squashfs size
SQUASHFS_SIZE=$(stat -c%s "$SQUASHFS_IMAGE" 2>/dev/null || stat -f%z "$SQUASHFS_IMAGE")
MAX_ROOTFS_SIZE=$((ROOTFS_A_SIZE_MIB * 1024 * 1024))
if [ "$SQUASHFS_SIZE" -gt "$MAX_ROOTFS_SIZE" ]; then
	die "Squashfs image ($SQUASHFS_SIZE bytes) exceeds slot size ($MAX_ROOTFS_SIZE bytes)"
fi

# ── Credential provisioning (EN18031: no default passwords) ────────────────────
# Each device must have a unique password set during provisioning.

log ""
log "=== Credential provisioning ==="
log ""

# Check for mkpasswd (usually in whois package)
if ! command -v mkpasswd &>/dev/null; then
	die "mkpasswd not found. Install 'whois' package: apt-get install whois"
fi

# Prompt for admin password
log "Set a password for the 'admin' user."
log "This password is used for Cockpit web access and SSH (LAN/VPN only)."
log ""
read -rsp "Enter admin password: " ADMIN_PASSWORD
echo
read -rsp "Confirm admin password: " ADMIN_PASSWORD_CONFIRM
echo

if [ "$ADMIN_PASSWORD" != "$ADMIN_PASSWORD_CONFIRM" ]; then
	die "Passwords do not match"
fi

if [ ${#ADMIN_PASSWORD} -lt 8 ]; then
	die "Password must be at least 8 characters"
fi

# Generate SHA-512 hash
ADMIN_PASSWORD_HASH=$(mkpasswd -m sha-512 "$ADMIN_PASSWORD")
log "Password hash generated"

# SSH public key (optional but recommended)
SSH_PUBKEY=""
if [ -n "$SSH_KEY" ]; then
	if [ -f "$SSH_KEY" ]; then
		SSH_PUBKEY=$(cat "$SSH_KEY")
	else
		SSH_PUBKEY="$SSH_KEY"
	fi
	# Validate it looks like an SSH key
	if ! echo "$SSH_PUBKEY" | grep -qE '^(ssh-rsa|ssh-ed25519|ecdsa-sha2|sk-ssh-ed25519|sk-ecdsa-sha2) '; then
		die "Invalid SSH public key: $SSH_KEY"
	fi
	log "SSH public key provided"
else
	log "No SSH key provided (--ssh-key). SSH key auth will not be available"
	log "until a key is manually deployed to /persist/config/ssh-authorized-keys/admin"
fi

# ── Idempotency check ─────────────────────────────────────────────────────────

if [ "$SKIP_CONFIRM" != "true" ]; then
	if sfdisk -d "$EMMC_DEV" &>/dev/null; then
		EXISTING_PARTS=$(sfdisk -d "$EMMC_DEV" 2>/dev/null | grep -c "^${EMMC_DEV}p" || true)
		if [ "$EXISTING_PARTS" -gt 0 ]; then
			log "WARNING: $EMMC_DEV already has $EXISTING_PARTS partition(s)"
			log "This will DESTROY all existing data on $EMMC_DEV"
			read -rp "Type 'yes' to continue: " CONFIRM
			if [ "$CONFIRM" != "yes" ]; then
				log "Aborted"
				exit 1
			fi
		fi
	fi
fi

# ── Unmount any existing partitions ────────────────────────────────────────────

log "Unmounting any existing partitions on $EMMC_DEV..."
for part in "${EMMC_DEV}p"*; do
	if mountpoint -q "$part" 2>/dev/null || mount | grep -q "$part"; then
		umount "$part" 2>/dev/null || true
	fi
done

# ── Write U-Boot ───────────────────────────────────────────────────────────────

log "Writing U-Boot idbloader.img to sector 64..."
dd if="$UBOOT_DIR/idbloader.img" of="$EMMC_DEV" seek=64 conv=notrunc bs=512 status=progress

log "Writing U-Boot u-boot.itb to sector 16384..."
dd if="$UBOOT_DIR/u-boot.itb" of="$EMMC_DEV" seek=16384 conv=notrunc bs=512 status=progress

# ── Partition the eMMC ─────────────────────────────────────────────────────────

log "Creating partition table..."
sfdisk "$EMMC_DEV" <<EOF
label: gpt

# boot slot A (vfat)
start=${BOOT_A_START_MIB}MiB, size=${BOOT_A_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="boot-a"

# boot slot B (vfat)
start=${BOOT_B_START_MIB}MiB, size=${BOOT_B_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="boot-b"

# rootfs slot A
start=${ROOTFS_A_START_MIB}MiB, size=${ROOTFS_A_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="rootfs-a"

# rootfs slot B
start=${ROOTFS_B_START_MIB}MiB, size=${ROOTFS_B_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="rootfs-b"
EOF

# Force kernel to re-read partition table
partprobe "$EMMC_DEV" || true
sleep 2

# ── Create filesystems ─────────────────────────────────────────────────────────

log "Creating vfat on boot slot A (${EMMC_DEV}p1)..."
mkfs.vfat -n "BOOT-A" "${EMMC_DEV}p1"

log "Creating vfat on boot slot B (${EMMC_DEV}p2)..."
mkfs.vfat -n "BOOT-B" "${EMMC_DEV}p2"

# rootfs partitions don't need a filesystem — squashfs is written directly
# /persist is NOT created here — systemd-repart handles it on first boot

# ── Deploy boot slot A ─────────────────────────────────────────────────────────

log "Deploying kernel and DTB to boot slot A..."
BOOT_A_MNT=$(mktemp -d)
mount "${EMMC_DEV}p1" "$BOOT_A_MNT"

mkdir -p "$BOOT_A_MNT/dtbs/rockchip"
cp "$KERNEL_IMAGE" "$BOOT_A_MNT/Image"
cp "$DTB_FILE" "$BOOT_A_MNT/dtbs/rockchip/rk3328-rock64.dtb"

umount "$BOOT_A_MNT"
rmdir "$BOOT_A_MNT"

# ── Deploy rootfs slot A ───────────────────────────────────────────────────────

log "Writing squashfs image to rootfs slot A (${EMMC_DEV}p3)..."
dd if="$SQUASHFS_IMAGE" of="${EMMC_DEV}p3" bs=4M status=progress

# ── Deploy credentials to persist ──────────────────────────────────────────────
# The persist partition doesn't exist yet (systemd-repart creates it on first
# boot). We need to create a temporary f2fs partition, write credentials, then
# wipe the partition so systemd-repart can do its job.
#
# Alternative approach: write credentials directly to a temporary mount of a
# pre-created persist partition. Since systemd-repart only creates partitions
# that don't already exist, we can pre-create the persist partition here.

log "Creating persist partition for credential deployment..."

# Create persist partition using remaining space
PERSIST_START_MIB=2320
sfdisk --append "$EMMC_DEV" <<EOF
start=${PERSIST_START_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="persist"
EOF
partprobe "$EMMC_DEV" || true
sleep 2

# Format as f2fs with label (matches systemd-repart config)
log "Formatting persist partition as f2fs..."
mkfs.f2fs -l persist -f "${EMMC_DEV}p5"

# Mount and deploy credentials
PERSIST_MNT=$(mktemp -d)
mount "${EMMC_DEV}p5" "$PERSIST_MNT"

mkdir -p "$PERSIST_MNT/config/ssh-authorized-keys"
mkdir -p "$PERSIST_MNT/config/cockpit"
mkdir -p "$PERSIST_MNT/config/traefik/dynamic"
mkdir -p "$PERSIST_MNT/config/traefik/certs"
mkdir -p "$PERSIST_MNT/containers"
mkdir -p "$PERSIST_MNT/logs"
mkdir -p "$PERSIST_MNT/rauc"

# Write password hash
echo "$ADMIN_PASSWORD_HASH" >"$PERSIST_MNT/config/admin-password-hash"
chmod 600 "$PERSIST_MNT/config/admin-password-hash"
log "Admin password hash written"

# Write SSH key if provided
if [ -n "$SSH_PUBKEY" ]; then
	echo "$SSH_PUBKEY" >"$PERSIST_MNT/config/ssh-authorized-keys/admin"
	chmod 600 "$PERSIST_MNT/config/ssh-authorized-keys/admin"
	log "SSH public key deployed for admin user"
fi

# ── Traefik reverse proxy configuration ────────────────────────────────────
# Generate a self-signed TLS certificate for initial HTTPS access.
# Replace with a proper CA-signed cert or enable ACME after deployment.

log "Generating self-signed TLS certificate for Traefik..."
if command -v openssl &>/dev/null; then
	openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
		-days 3650 -nodes \
		-keyout "$PERSIST_MNT/config/traefik/certs/server.key" \
		-out "$PERSIST_MNT/config/traefik/certs/server.crt" \
		-subj "/CN=gateway" \
		-addext "subjectAltName=DNS:gateway,DNS:gateway.local,IP:172.20.30.1" \
		2>/dev/null
	chmod 600 "$PERSIST_MNT/config/traefik/certs/server.key"
	chmod 644 "$PERSIST_MNT/config/traefik/certs/server.crt"
	log "TLS certificate generated (self-signed, 10-year expiry)"
else
	log "WARNING: openssl not found, skipping TLS cert generation"
	log "You must deploy certs to /persist/config/traefik/certs/ before Traefik will serve HTTPS"
fi

# Write Traefik static configuration
cat >"$PERSIST_MNT/config/traefik/traefik.yaml" <<'TRAEFIK_STATIC'
# Traefik static configuration — gateway device
# https://doc.traefik.io/traefik/reference/static-configuration/file/

entryPoints:
  websecure:
    address: ":443"
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https

providers:
  file:
    directory: /etc/traefik/dynamic
    watch: true

# No access log by default — enable in dynamic config if needed
log:
  level: WARN

# Disable Traefik dashboard (not exposed externally)
api:
  dashboard: false

# Disable telemetry
global:
  sendAnonymousUsage: false
TRAEFIK_STATIC
log "Traefik static config written"

# Write Traefik dynamic configuration — Cockpit route + TLS
cat >"$PERSIST_MNT/config/traefik/dynamic/cockpit.yaml" <<'TRAEFIK_COCKPIT'
# Cockpit reverse proxy route
# Traefik terminates TLS and forwards to Cockpit on localhost:9090 (plain HTTP).

http:
  routers:
    cockpit:
      rule: "PathPrefix(`/`)"
      entryPoints:
        - websecure
      service: cockpit
      tls: {}

  services:
    cockpit:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9090"

tls:
  stores:
    default:
      defaultCertificate:
        certFile: /etc/traefik/certs/server.crt
        keyFile: /etc/traefik/certs/server.key
TRAEFIK_COCKPIT
log "Traefik Cockpit route config written"

# Write OIDC forward-auth template (disabled by default)
# To enable: update authUrl with your Microsoft Entra tenant details
cat >"$PERSIST_MNT/config/traefik/dynamic/oidc.yaml.disabled" <<'TRAEFIK_OIDC'
# OIDC forward-auth middleware (Microsoft Entra)
# Rename this file to oidc.yaml to enable.
#
# ── Authentication flow evaluation ──
#
# Cockpit (pod) authenticates via SSH to localhost. It supports a [bearer]
# auth scheme in cockpit.conf where a custom command verifies bearer tokens.
# However, even with bearer auth, Cockpit still needs SSH credentials to
# spawn the Python bridge on the host.
#
# RECOMMENDED APPROACH: "OIDC gatekeeper + Cockpit password"
#   1. WAN request → Traefik (port 443)
#   2. Traefik forward-auth → OIDC provider (Microsoft Entra)
#   3. On OIDC success: Traefik proxies to Cockpit (127.0.0.1:9090)
#   4. Cockpit shows its login page — user enters device password
#   5. Cockpit SSHes to localhost with that password
#
# This gives two-factor access: identity (OIDC) + device credential (password).
# LAN clients bypass OIDC (ipAllowList middleware) and go directly to step 4.
#
# ALTERNATIVE: "Trusted header auto-login" (future enhancement)
#   Deploy a custom Cockpit auth command under [bearer] in cockpit.conf
#   that trusts X-Forwarded-User from Traefik and uses an SSH service key
#   to spawn the bridge without password entry. This provides SSO but
#   requires careful trust boundary management (only Traefik on loopback
#   should be able to set X-Forwarded-User).
#
# ── Setup instructions ──
#
# 1. Deploy a forward-auth service (e.g. thomseddon/traefik-forward-auth
#    or mesosphere/traefik-forward-auth) as a podman container.
# 2. Configure it with your Microsoft Entra tenant/client ID.
# 3. Update the address below to point to your forward-auth service.
# 4. Rename this file to oidc.yaml.
# 5. Update cockpit.yaml router to include the oidc-chain middleware.
#
# Requires a forward-auth service running on the device.

http:
  middlewares:
    oidc-auth:
      forwardAuth:
        # Update this URL to point to your forward-auth service
        address: "http://127.0.0.1:4181"
        trustForwardHeader: true
        authResponseHeaders:
          - X-Forwarded-User
          - X-Forwarded-Groups
          - X-Forwarded-Email

    lan-bypass:
      ipAllowList:
        sourceRange:
          - "172.20.30.0/24"
          - "127.0.0.1/8"

    # Chain: LAN clients bypass OIDC; WAN clients go through OIDC first.
    # Apply this chain to the cockpit router instead of individual middlewares.
    oidc-chain:
      chain:
        middlewares:
          - lan-bypass
          - oidc-auth

  # To activate: update the cockpit router in cockpit.yaml to include:
  #   middlewares:
  #     - oidc-chain
TRAEFIK_OIDC
log "OIDC forward-auth template written (disabled)"

# ── Health manifest ────────────────────────────────────────────────────────
# The os-verification service reads this file to validate that required
# containers are running before committing a RAUC slot.
cat >"$PERSIST_MNT/config/health-manifest.yaml" <<'HEALTH_MANIFEST'
# Health manifest — containers validated by os-verification service
# before committing a RAUC slot as "good".
containers:
  - name: cockpit-ws
  - name: traefik
HEALTH_MANIFEST
log "Health manifest written (cockpit-ws, traefik)"

umount "$PERSIST_MNT"
rmdir "$PERSIST_MNT"

# ── Validation ─────────────────────────────────────────────────────────────────
# Verify credentials were written correctly

log "Validating provisioned credentials..."
VALIDATE_MNT=$(mktemp -d)
mount -o ro "${EMMC_DEV}p5" "$VALIDATE_MNT"

VALID=true

if [ ! -f "$VALIDATE_MNT/config/admin-password-hash" ]; then
	log "FAIL: admin-password-hash not found"
	VALID=false
elif [ ! -s "$VALIDATE_MNT/config/admin-password-hash" ]; then
	log "FAIL: admin-password-hash is empty"
	VALID=false
else
	log "OK: admin-password-hash present"
fi

if [ -n "$SSH_PUBKEY" ]; then
	if [ ! -f "$VALIDATE_MNT/config/ssh-authorized-keys/admin" ]; then
		log "FAIL: SSH key not found"
		VALID=false
	else
		log "OK: SSH key present"
	fi
fi

if [ ! -f "$VALIDATE_MNT/config/traefik/traefik.yaml" ]; then
	log "FAIL: Traefik static config not found"
	VALID=false
else
	log "OK: Traefik static config present"
fi

if [ ! -f "$VALIDATE_MNT/config/traefik/dynamic/cockpit.yaml" ]; then
	log "FAIL: Traefik Cockpit route not found"
	VALID=false
else
	log "OK: Traefik Cockpit route present"
fi

if [ ! -f "$VALIDATE_MNT/config/health-manifest.yaml" ]; then
	log "FAIL: Health manifest not found"
	VALID=false
else
	log "OK: Health manifest present"
fi

umount "$VALIDATE_MNT"
rmdir "$VALIDATE_MNT"

if [ "$VALID" != "true" ]; then
	die "Credential validation failed. Device may not boot correctly."
fi

# ── Done ───────────────────────────────────────────────────────────────────────

log ""
log "=== Provisioning complete ==="
log ""
log "Partition layout on $EMMC_DEV:"
log "  p1: boot-a   (vfat, ${BOOT_A_SIZE_MIB} MiB) — kernel + DTB"
log "  p2: boot-b   (vfat, ${BOOT_B_SIZE_MIB} MiB) — empty (for future updates)"
log "  p3: rootfs-a  (${ROOTFS_A_SIZE_MIB} MiB)     — squashfs deployed"
log "  p4: rootfs-b  (${ROOTFS_B_SIZE_MIB} MiB)     — empty (for future updates)"
log "  p5: persist   (f2fs, remaining space)        — credentials + config deployed"
log ""
log "Credentials:"
log "  admin password: SET (hashed)"
if [ -n "$SSH_PUBKEY" ]; then
	log "  admin SSH key:  DEPLOYED"
else
	log "  admin SSH key:  NOT SET (deploy manually to /persist/config/ssh-authorized-keys/admin)"
fi
log ""
log "Services:"
log "  Traefik:  config at /persist/config/traefik/ (self-signed TLS)"
log "  Cockpit:  routed via Traefik on port 443"
log "  OIDC:     disabled (enable via /persist/config/traefik/dynamic/oidc.yaml)"
log ""
log "Health manifest: /persist/config/health-manifest.yaml (cockpit-ws, traefik)"
log ""
log "NOTE: Container images (cockpit-ws, traefik) must be pulled on first boot"
log "or pre-loaded via 'podman pull' before the device goes live."
log ""
log "U-Boot env will default to: BOOT_ORDER=A B, BOOT_A_LEFT=3"
log "Remove SD card and reboot to boot from eMMC."
