#!/usr/bin/env bash
#MISE description="Flash image directly to eMMC block device (requires Linux + root)"
#MISE depends=["build"]
#USAGE flag "-y --yes" help="Skip confirmation prompt"
#USAGE flag "--ssh-key <key>" help="SSH public key (or path to .pub file) for admin user"
#USAGE arg "<emmc-device>" help="eMMC block device (e.g. /dev/mmcblk1)"
#USAGE arg "<uboot-dir>" help="Directory containing idbloader.img and u-boot.itb"
#USAGE arg "<kernel-image>" help="Path to kernel Image file"
#USAGE arg "<dtb-file>" help="Path to DTB file (e.g. rk3328-rock64.dtb)"
#USAGE arg "<squashfs-image>" help="Path to squashfs root filesystem image"
set -euo pipefail

# ── Platform check ─────────────────────────────────────────────────────────────

if [ "$(uname -s)" != "Linux" ]; then
	echo "ERROR: This task must run on Linux (requires block device access, mount, sfdisk)."
	echo "Run from inside a Linux VM (e.g. limactl shell) with the eMMC device attached."
	exit 1
fi

# ── Arguments ──────────────────────────────────────────────────────────────────

EMMC_DEV="${usage_emmc_device}"
UBOOT_DIR="${usage_uboot_dir}"
KERNEL_IMAGE="${usage_kernel_image}"
DTB_FILE="${usage_dtb_file}"
SQUASHFS_IMAGE="${usage_squashfs_image}"
SKIP_CONFIRM="${usage_yes:-false}"
SSH_KEY="${usage_ssh_key:-}"

# ── Partition layout (sizes in MiB) ───────────────────────────────────────────
#
# Offset     Size       Content
# 0          4 MiB      U-Boot (raw, idbloader @ sector 64, u-boot.itb @ sector 16384)
# 4 MiB      128 MiB    boot slot A (vfat) — kernel + DTB
# 132 MiB    128 MiB    boot slot B (vfat) — kernel + DTB
# 260 MiB    1024 MiB   rootfs slot A (squashfs)
# 1284 MiB   1024 MiB   rootfs slot B (squashfs)
# 2308 MiB   remaining  /persist (f2fs) — created by systemd-repart on first boot
#
# Note: the /persist partition is not created here. systemd-repart creates and
# formats it as f2fs on first boot, filling all remaining eMMC space.

BOOT_A_START_MIB=4
BOOT_A_SIZE_MIB=128
BOOT_B_START_MIB=132
BOOT_B_SIZE_MIB=128
ROOTFS_A_START_MIB=260
ROOTFS_A_SIZE_MIB=1024
ROOTFS_B_START_MIB=1284
ROOTFS_B_SIZE_MIB=1024

# ── Validation ─────────────────────────────────────────────────────────────────

log() { echo "[provision] $*"; }
die() {
	echo "[provision] ERROR: $*" >&2
	exit 1
}

[ "$(id -u)" -eq 0 ] || die "Must run as root"
[ -b "$EMMC_DEV" ] || die "Not a block device: $EMMC_DEV"
[ -d "$UBOOT_DIR" ] || die "Not a directory: $UBOOT_DIR"
[ -f "$UBOOT_DIR/idbloader.img" ] || die "Missing $UBOOT_DIR/idbloader.img"
[ -f "$UBOOT_DIR/u-boot.itb" ] || die "Missing $UBOOT_DIR/u-boot.itb"
[ -f "$KERNEL_IMAGE" ] || die "Missing kernel image: $KERNEL_IMAGE"
[ -f "$DTB_FILE" ] || die "Missing DTB: $DTB_FILE"
[ -f "$SQUASHFS_IMAGE" ] || die "Missing squashfs image: $SQUASHFS_IMAGE"

# Check squashfs size
SQUASHFS_SIZE=$(stat -c%s "$SQUASHFS_IMAGE" 2>/dev/null || stat -f%z "$SQUASHFS_IMAGE")
MAX_ROOTFS_SIZE=$((ROOTFS_A_SIZE_MIB * 1024 * 1024))
if [ "$SQUASHFS_SIZE" -gt "$MAX_ROOTFS_SIZE" ]; then
	die "Squashfs image ($SQUASHFS_SIZE bytes) exceeds slot size ($MAX_ROOTFS_SIZE bytes)"
fi

# ── Credential provisioning (EN18031: no default passwords) ────────────────────
# Each device must have a unique password set during provisioning.

log ""
log "=== Credential provisioning ==="
log ""

# Check for mkpasswd (usually in whois package)
if ! command -v mkpasswd &>/dev/null; then
	die "mkpasswd not found. Install 'whois' package: apt-get install whois"
fi

# Prompt for admin password
log "Set a password for the 'admin' user."
log "This password is used for Cockpit web access and SSH (LAN/VPN only)."
log ""
read -rsp "Enter admin password: " ADMIN_PASSWORD
echo
read -rsp "Confirm admin password: " ADMIN_PASSWORD_CONFIRM
echo

if [ "$ADMIN_PASSWORD" != "$ADMIN_PASSWORD_CONFIRM" ]; then
	die "Passwords do not match"
fi

if [ ${#ADMIN_PASSWORD} -lt 8 ]; then
	die "Password must be at least 8 characters"
fi

# Generate SHA-512 hash
ADMIN_PASSWORD_HASH=$(mkpasswd -m sha-512 "$ADMIN_PASSWORD")
log "Password hash generated"

# SSH public key (optional but recommended)
SSH_PUBKEY=""
if [ -n "$SSH_KEY" ]; then
	if [ -f "$SSH_KEY" ]; then
		SSH_PUBKEY=$(cat "$SSH_KEY")
	else
		SSH_PUBKEY="$SSH_KEY"
	fi
	# Validate it looks like an SSH key
	if ! echo "$SSH_PUBKEY" | grep -qE '^(ssh-rsa|ssh-ed25519|ecdsa-sha2|sk-ssh-ed25519|sk-ecdsa-sha2) '; then
		die "Invalid SSH public key: $SSH_KEY"
	fi
	log "SSH public key provided"
else
	log "No SSH key provided (--ssh-key). SSH key auth will not be available"
	log "until a key is manually deployed to /persist/config/ssh-authorized-keys/admin"
fi

# ── Idempotency check ─────────────────────────────────────────────────────────

if [ "$SKIP_CONFIRM" != "true" ]; then
	if sfdisk -d "$EMMC_DEV" &>/dev/null; then
		EXISTING_PARTS=$(sfdisk -d "$EMMC_DEV" 2>/dev/null | grep -c "^${EMMC_DEV}p" || true)
		if [ "$EXISTING_PARTS" -gt 0 ]; then
			log "WARNING: $EMMC_DEV already has $EXISTING_PARTS partition(s)"
			log "This will DESTROY all existing data on $EMMC_DEV"
			read -rp "Type 'yes' to continue: " CONFIRM
			if [ "$CONFIRM" != "yes" ]; then
				log "Aborted"
				exit 1
			fi
		fi
	fi
fi

# ── Unmount any existing partitions ────────────────────────────────────────────

log "Unmounting any existing partitions on $EMMC_DEV..."
for part in "${EMMC_DEV}p"*; do
	if mountpoint -q "$part" 2>/dev/null || mount | grep -q "$part"; then
		umount "$part" 2>/dev/null || true
	fi
done

# ── Write U-Boot ───────────────────────────────────────────────────────────────

log "Writing U-Boot idbloader.img to sector 64..."
dd if="$UBOOT_DIR/idbloader.img" of="$EMMC_DEV" seek=64 conv=notrunc bs=512 status=progress

log "Writing U-Boot u-boot.itb to sector 16384..."
dd if="$UBOOT_DIR/u-boot.itb" of="$EMMC_DEV" seek=16384 conv=notrunc bs=512 status=progress

# ── Partition the eMMC ─────────────────────────────────────────────────────────

log "Creating partition table..."
sfdisk "$EMMC_DEV" <<EOF
label: gpt

# boot slot A (vfat)
start=${BOOT_A_START_MIB}MiB, size=${BOOT_A_SIZE_MIB}MiB, type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, name="boot-a"

# boot slot B (vfat)
start=${BOOT_B_START_MIB}MiB, size=${BOOT_B_SIZE_MIB}MiB, type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, name="boot-b"

# rootfs slot A
start=${ROOTFS_A_START_MIB}MiB, size=${ROOTFS_A_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="rootfs-a"

# rootfs slot B
start=${ROOTFS_B_START_MIB}MiB, size=${ROOTFS_B_SIZE_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="rootfs-b"
EOF

# Force kernel to re-read partition table
partprobe "$EMMC_DEV" || true
sleep 2

# ── Create filesystems ─────────────────────────────────────────────────────────

log "Creating vfat on boot slot A (${EMMC_DEV}p1)..."
mkfs.vfat -n "BOOT-A" "${EMMC_DEV}p1"

log "Creating vfat on boot slot B (${EMMC_DEV}p2)..."
mkfs.vfat -n "BOOT-B" "${EMMC_DEV}p2"

# rootfs partitions don't need a filesystem — squashfs is written directly
# /persist is NOT created here — systemd-repart handles it on first boot

# ── Deploy boot slot A ─────────────────────────────────────────────────────────

log "Deploying kernel and DTB to boot slot A..."
BOOT_A_MNT=$(mktemp -d)
mount "${EMMC_DEV}p1" "$BOOT_A_MNT"

mkdir -p "$BOOT_A_MNT/dtbs/rockchip"
cp "$KERNEL_IMAGE" "$BOOT_A_MNT/Image"
cp "$DTB_FILE" "$BOOT_A_MNT/dtbs/rockchip/rk3328-rock64.dtb"

umount "$BOOT_A_MNT"
rmdir "$BOOT_A_MNT"

# ── Deploy rootfs slot A ───────────────────────────────────────────────────────

log "Writing squashfs image to rootfs slot A (${EMMC_DEV}p3)..."
dd if="$SQUASHFS_IMAGE" of="${EMMC_DEV}p3" bs=4M status=progress

# ── Deploy credentials to persist ──────────────────────────────────────────────
# The persist partition doesn't exist yet (systemd-repart creates it on first
# boot). We need to create a temporary f2fs partition, write credentials, then
# wipe the partition so systemd-repart can do its job.
#
# Alternative approach: write credentials directly to a temporary mount of a
# pre-created persist partition. Since systemd-repart only creates partitions
# that don't already exist, we can pre-create the persist partition here.

log "Creating persist partition for credential deployment..."

# Create persist partition using remaining space
PERSIST_START_MIB=2308
sfdisk --append "$EMMC_DEV" <<EOF
start=${PERSIST_START_MIB}MiB, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="persist"
EOF
partprobe "$EMMC_DEV" || true
sleep 2

# Format as f2fs with label (matches systemd-repart config)
log "Formatting persist partition as f2fs..."
mkfs.f2fs -l persist -f "${EMMC_DEV}p5"

# Mount and deploy credentials
PERSIST_MNT=$(mktemp -d)
mount "${EMMC_DEV}p5" "$PERSIST_MNT"

mkdir -p "$PERSIST_MNT/config/ssh-authorized-keys"
mkdir -p "$PERSIST_MNT/config/cockpit"
mkdir -p "$PERSIST_MNT/containers"
mkdir -p "$PERSIST_MNT/logs"
mkdir -p "$PERSIST_MNT/rauc"

# Write password hash
echo "$ADMIN_PASSWORD_HASH" >"$PERSIST_MNT/config/admin-password-hash"
chmod 600 "$PERSIST_MNT/config/admin-password-hash"
log "Admin password hash written"

# Write SSH key if provided
if [ -n "$SSH_PUBKEY" ]; then
	echo "$SSH_PUBKEY" >"$PERSIST_MNT/config/ssh-authorized-keys/admin"
	chmod 600 "$PERSIST_MNT/config/ssh-authorized-keys/admin"
	log "SSH public key deployed for admin user"
fi

umount "$PERSIST_MNT"
rmdir "$PERSIST_MNT"

# ── Validation ─────────────────────────────────────────────────────────────────
# Verify credentials were written correctly

log "Validating provisioned credentials..."
VALIDATE_MNT=$(mktemp -d)
mount -o ro "${EMMC_DEV}p5" "$VALIDATE_MNT"

VALID=true

if [ ! -f "$VALIDATE_MNT/config/admin-password-hash" ]; then
	log "FAIL: admin-password-hash not found"
	VALID=false
elif [ ! -s "$VALIDATE_MNT/config/admin-password-hash" ]; then
	log "FAIL: admin-password-hash is empty"
	VALID=false
else
	log "OK: admin-password-hash present"
fi

if [ -n "$SSH_PUBKEY" ]; then
	if [ ! -f "$VALIDATE_MNT/config/ssh-authorized-keys/admin" ]; then
		log "FAIL: SSH key not found"
		VALID=false
	else
		log "OK: SSH key present"
	fi
fi

umount "$VALIDATE_MNT"
rmdir "$VALIDATE_MNT"

if [ "$VALID" != "true" ]; then
	die "Credential validation failed. Device may not boot correctly."
fi

# ── Done ───────────────────────────────────────────────────────────────────────

log ""
log "=== Provisioning complete ==="
log ""
log "Partition layout on $EMMC_DEV:"
log "  p1: boot-a   (vfat, ${BOOT_A_SIZE_MIB} MiB) — kernel + DTB"
log "  p2: boot-b   (vfat, ${BOOT_B_SIZE_MIB} MiB) — empty (for future updates)"
log "  p3: rootfs-a  (${ROOTFS_A_SIZE_MIB} MiB)     — squashfs deployed"
log "  p4: rootfs-b  (${ROOTFS_B_SIZE_MIB} MiB)     — empty (for future updates)"
log "  p5: persist   (f2fs, remaining space)        — credentials deployed"
log ""
log "Credentials:"
log "  admin password: SET (hashed)"
if [ -n "$SSH_PUBKEY" ]; then
	log "  admin SSH key:  DEPLOYED"
else
	log "  admin SSH key:  NOT SET (deploy manually to /persist/config/ssh-authorized-keys/admin)"
fi
log ""
log "U-Boot env will default to: BOOT_ORDER=A B, BOOT_A_LEFT=3"
log "Remove SD card and reboot to boot from eMMC."
