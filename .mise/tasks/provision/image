#!/usr/bin/env bash
#MISE description="Generate a flashable eMMC disk image (builds all artifacts first)"
#MISE depends=["build:image"]
#USAGE flag "-o --output <path>" help="Output image path" default="atomixos-<series>.img"
set -euo pipefail

IMAGE_SRC=""
for candidate in result-image/atomixos-*.img; do
	if [ -f "$candidate" ]; then
		IMAGE_SRC="$candidate"
		break
	fi
done

if [ -z "$IMAGE_SRC" ] || [ ! -f "$IMAGE_SRC" ]; then
    echo "ERROR: Image not found at result-image/atomixos-*.img"
    echo "The build:image task should have created it. Check for build errors above."
    exit 1
fi

OUTPUT_PATH="${usage_output:-atomixos-<series>.img}"
if [ "$OUTPUT_PATH" = "atomixos-<series>.img" ]; then
	OUTPUT_PATH=$(basename "$IMAGE_SRC")
fi

cp "$IMAGE_SRC" "$OUTPUT_PATH"
echo "Flashable image written to: $OUTPUT_PATH"
echo ""

SIZE=$(stat -c%s "$OUTPUT_PATH" 2>/dev/null || stat -f%z "$OUTPUT_PATH")
echo "Size: $((SIZE / 1024 / 1024)) MiB"
echo ""
echo "Flash with:"
echo "  dd if=$OUTPUT_PATH of=/dev/mmcblkN bs=4M status=progress"
echo "  Or use a tool like Etcher."
echo ""
echo "On first boot, systemd-repart will create and format the /persist"
echo "partition (f2fs) using all remaining eMMC space."
