#!/usr/bin/env bash
#MISE description="Capture Rock64 serial console output (UART2 @ 1.5Mbaud)"
#USAGE flag "-p --port <path>" help="Serial device path (default: auto-detect /dev/cu.usbserial-*)"
#USAGE flag "-l --log <path>" help="Log file path (default: /tmp/rock64-serial.log)"
#USAGE flag "--bg" help="Run in background. Kills any existing capture first. Prints PID to stdout."
set -euo pipefail

SERIAL_LOG="${usage_log:-/tmp/rock64-serial.log}"

# Auto-detect serial device (cu.* not tty.* — macOS tty.* waits for DCD)
auto_detect_port() {
	local port
	port="$(find /dev -maxdepth 1 -name 'cu.usbserial-*' 2>/dev/null | head -1)"
	if [ -z "$port" ]; then
		echo "ERROR: No USB-serial adapter found (/dev/cu.usbserial-*)" >&2
		echo "" >&2
		echo "Check that the adapter is plugged in firmly." >&2
		exit 1
	fi
	echo "$port"
}

if [ -n "${usage_port:-}" ]; then
	SERIAL_PORT="$usage_port"
else
	SERIAL_PORT="$(auto_detect_port)"
fi

# Resolve minicom binary via nix (same approach as serial:shell)
MINICOM="$(nix build nixpkgs#minicom --no-link --print-out-paths 2>/dev/null)/bin/minicom"
if [ ! -x "$MINICOM" ]; then
	echo "ERROR: Failed to resolve minicom via nix. Try: nix build nixpkgs#minicom"
	exit 1
fi

if [ "${usage_bg:-false}" = "true" ]; then
	# Background mode: kill existing capture, truncate log, launch minicom headless
	pkill -f "minicom.*capture" 2>/dev/null || true
	pkill -f "minicom -D.*cu.usbserial" 2>/dev/null || true
	sleep 1
	: > "$SERIAL_LOG"

	# Run minicom in background with capture file.
	# -C = capture file, -o = skip init, no terminal needed via script -q /dev/null
	nohup script -q /dev/null "$MINICOM" -D "$SERIAL_PORT" -b 1500000 -o -C "$SERIAL_LOG" \
		> /dev/null 2>&1 &

	BG_PID=$!
	echo "Serial capture running in background (PID $BG_PID)"
	echo "  Log: $SERIAL_LOG"
	echo "  Stop: pkill -f 'minicom -D'"
	exit 0
fi

# Foreground mode: capture to file and show on screen
echo "=== Rock64 Serial Capture ==="
echo ""
echo "  Port: $SERIAL_PORT"
echo "  Baud: 1500000"
echo "  Log:  $SERIAL_LOG"
echo ""
echo "Press Ctrl-A X to stop."
echo ""

exec "$MINICOM" -D "$SERIAL_PORT" -b 1500000 -o -C "$SERIAL_LOG"
