#!/usr/bin/env bash
#MISE description="Capture Rock64 serial console output (UART2 @ 1.5Mbaud)"
#USAGE flag "-p --port <path>" help="Serial device path (default: auto-detect /dev/cu.usbserial-*)"
#USAGE flag "-l --log <path>" help="Log file path (default: /tmp/rock64-serial.log)"
#USAGE flag "-t --timeout <secs>" help="Capture timeout in seconds, 0=infinite (default: 0)"
set -euo pipefail

# Auto-detect serial device (cu.* not tty.* — macOS tty.* waits for DCD)
if [ -n "${usage_port:-}" ]; then
	SERIAL_PORT="$usage_port"
else
	SERIAL_PORT="$(find /dev -maxdepth 1 -name 'cu.usbserial-*' 2>/dev/null | head -1)"
	if [ -z "$SERIAL_PORT" ]; then
		echo "ERROR: No USB-serial adapter found (/dev/cu.usbserial-*)"
		echo ""
		echo "Check that the adapter is plugged in firmly."
		exit 1
	fi
fi

export SERIAL_PORT
export SERIAL_LOG="${usage_log:-/tmp/rock64-serial.log}"
export SERIAL_TIMEOUT="${usage_timeout:-0}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

echo "=== Rock64 Serial Capture ==="
echo ""
echo "  Port:    $SERIAL_PORT"
echo "  Baud:    1500000"
echo "  Log:     $SERIAL_LOG"
if [ "$SERIAL_TIMEOUT" != "0" ]; then
	echo "  Timeout: ${SERIAL_TIMEOUT}s"
fi
echo ""
echo "Auto-reconnects on USB disconnect. Press Ctrl+C to stop."
echo ""

exec nix-shell -p python3Packages.pyserial --run "python3 $SCRIPT_DIR/scripts/serial-capture.py"
