#!/usr/bin/env bash
#MISE description="Run os-verification confirmation E2E test"
#MISE alias="confirm"
set -euo pipefail

ARCH="aarch64-linux"
[[ "$(uname -s)" == "Darwin" ]] && ARCH="aarch64-darwin"

echo "Running E2E test: rauc-confirm ($ARCH)"
echo "  Runs os-verification.sh health checks, verifies slot marked good"
echo "  (includes 60s sustained health check — expect ~3 min total)"
echo ""
nix build ".#checks.${ARCH}.rauc-confirm" --no-link --print-build-logs \
	2> >(grep -v 'SQLite database.*is busy' >&2)
echo ""
echo "PASS: rauc-confirm"
