#!/usr/bin/env bash
#MISE description="Run nftables firewall rules E2E test"
#MISE alias="firewall"
#USAGE flag "--lima" help="Run inside a Lima VM"
#USAGE flag "--vm <name>" help="Lima VM instance name" default="default"
set -euo pipefail

cmd=()
if [ "${usage_lima:-false}" = "true" ]; then
	if ! command -v limactl >/dev/null 2>&1; then
		echo "ERROR: limactl not found. Install Lima: https://lima-vm.io/"
		exit 1
	fi
	limactl start "${usage_vm}" 2>/dev/null || true
	cmd+=(limactl shell "${usage_vm}" --)
fi

ARCH="aarch64-linux"
if [ "${usage_lima:-false}" != "true" ] && [[ "$(uname -s)" == "Darwin" ]]; then
	ARCH="aarch64-darwin"
fi

echo "Running E2E test: firewall ($ARCH)"
echo "  Verifies WAN/LAN/VPN firewall rules with multi-node VLAN setup"
echo ""
"${cmd[@]}" nix build ".#checks.${ARCH}.firewall" --no-link --print-build-logs \
	2> >(grep -v 'SQLite database.*is busy' >&2)
echo ""
echo "PASS: firewall"
