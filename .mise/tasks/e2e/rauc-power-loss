#!/usr/bin/env bash
#MISE description="Run RAUC power-loss simulation E2E test"
#MISE alias="power-loss"
set -euo pipefail

ARCH="aarch64-linux"
[[ "$(uname -s)" == "Darwin" ]] && ARCH="aarch64-darwin"

echo "Running E2E test: rauc-power-loss ($ARCH)"
echo "  Crashes VM during RAUC install, verifies slot A intact after reboot"
echo ""
nix build ".#checks.${ARCH}.rauc-power-loss" --no-link --print-build-logs \
	2> >(grep -v 'SQLite database.*is busy' >&2)
echo ""
echo "PASS: rauc-power-loss"
