#!/usr/bin/env bash
#MISE description="Set built-in fallback LAN gateway/DHCP defaults"
#USAGE flag "--gateway-cidr <value>" help="LAN gateway CIDR for eth1 (e.g. 172.20.30.1/24)" default="172.20.30.1/24"
#USAGE flag "--dhcp-start <value>" help="DHCP range start IP (e.g. 172.20.30.10)" default="172.20.30.10"
#USAGE flag "--dhcp-end <value>" help="DHCP range end IP (e.g. 172.20.30.254)" default="172.20.30.254"
set -euo pipefail
# shellcheck disable=SC2154 # mise injects usage_* variables from #USAGE

ROOT_DIR="$(git rev-parse --show-toplevel)"

LAN_GATEWAY_NIX="$ROOT_DIR/modules/lan-gateway.nix"

GATEWAY_CIDR="${usage_gateway_cidr:-172.20.30.1/24}"
DHCP_START="${usage_dhcp_start:-172.20.30.10}"
DHCP_END="${usage_dhcp_end:-172.20.30.254}"

GATEWAY_IP="${GATEWAY_CIDR%/*}"
PREFIX="${GATEWAY_CIDR#*/}"

if [[ "$GATEWAY_CIDR" == "$GATEWAY_IP" ]]; then
	echo "ERROR: --gateway-cidr must include CIDR suffix (example: 10.50.0.1/24)"
	exit 1
fi

if ! [[ "$GATEWAY_IP" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
	echo "ERROR: invalid gateway IP: $GATEWAY_IP"
	exit 1
fi

for octet in ${GATEWAY_IP//./ }; do
	if [ "$octet" -lt 0 ] || [ "$octet" -gt 255 ]; then
		echo "ERROR: invalid gateway IP: $GATEWAY_IP"
		exit 1
	fi
done

if ! [[ "$PREFIX" =~ ^[0-9]+$ ]] || [ "$PREFIX" -lt 1 ] || [ "$PREFIX" -gt 32 ]; then
	echo "ERROR: invalid CIDR prefix: $PREFIX"
	exit 1
fi

if [ "$PREFIX" != "24" ]; then
	echo "ERROR: only /24 is supported by this helper right now"
	echo "       got: $GATEWAY_CIDR"
	exit 1
fi

SUBNET_PREFIX="${GATEWAY_IP%.*}"
SUBNET_CIDR="$SUBNET_PREFIX.0/$PREFIX"
NETMASK="255.255.255.0"

for ip in "$DHCP_START" "$DHCP_END"; do
	if ! [[ "$ip" =~ ^${SUBNET_PREFIX//./\.}\.[0-9]{1,3}$ ]]; then
		echo "ERROR: DHCP IP $ip is not in subnet $SUBNET_CIDR"
		exit 1
	fi
	last="${ip##*.}"
	if [ "$last" -lt 1 ] || [ "$last" -gt 254 ]; then
		echo "ERROR: DHCP IP $ip has invalid host octet"
		exit 1
	fi
done

python3 - <<'PY' "$LAN_GATEWAY_NIX" "$GATEWAY_CIDR" "$GATEWAY_IP" "$DHCP_START" "$DHCP_END" "$NETMASK" "$SUBNET_CIDR"
import pathlib
import re
import sys

lan_gateway, gateway_cidr, gateway_ip, dhcp_start, dhcp_end, netmask, subnet_cidr = sys.argv[1:]

def replace_file(path: str, patterns: list[tuple[str, str]]) -> None:
    p = pathlib.Path(path)
    text = p.read_text()
    original = text
    for pattern, repl in patterns:
        text, count = re.subn(pattern, repl, text, flags=re.MULTILINE)
        if count == 0:
            raise SystemExit(f"ERROR: pattern not found in {path}: {pattern}")
    if text != original:
        p.write_text(text)

replace_file(lan_gateway, [
    (r'Address=[0-9.]+/[0-9]+', f'Address={gateway_cidr}'),
    (r'dhcp-range=[0-9.]+,[0-9.]+,[0-9.]+,24h', f'dhcp-range={dhcp_start},{dhcp_end},{netmask},24h'),
    (r'dhcp-option=3,[0-9.]+', f'dhcp-option=3,{gateway_ip}'),
    (r'dhcp-option=6,[0-9.]+', f'dhcp-option=6,{gateway_ip}'),
    (r'dhcp-option=42,[0-9.]+', f'dhcp-option=42,{gateway_ip}'),
    (r'[0-9.]+ atomixos atomixos\.local', f'{gateway_ip} atomixos atomixos.local'),
    (r'allow\s+[0-9.]+/[0-9]+', f'allow {subnet_cidr}'),
])

PY

echo "Updated LAN settings:"
echo "  gateway:    $GATEWAY_CIDR"
echo "  subnet:     $SUBNET_CIDR"
echo "  dhcp range: $DHCP_START - $DHCP_END"
echo ""
echo "Updated files:"
echo "  modules/lan-gateway.nix"
echo ""
echo "Next steps:"
echo "  mise run check"
echo "  mise run build"
