<!DOCTYPE html>
<html lang="en" class="h-full bg-blue-100">
  <head>
    <title>{{ .MetaTitle }} - {{ .PageTitle }}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="{{ .MetaDescription }}" />
    <meta name="author" content="{{ .MetaAuthor }}" />
    <script>
      (function () {
        var style = localStorage.getItem("shell:style") || "auto";
        var dark = style === "dark" || (style === "auto" && window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);
        if (dark) document.documentElement.classList.add("pf-v6-theme-dark");
      })();
    </script>
    <link rel="shortcut icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/google-webfonts/roboto.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/line-awesome/line-awesome.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/login.css" }}" />
    {{ if eq .Data.ui_options.custom_css_required "yes" }}
      <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/custom.css" }}" />
    {{ end }}
  </head>

  {{ $qrCodeLink := pathjoin .ActionEndpoint "/qrcode/login.png" }}

  <body class="h-full">
    <button type="button" class="atomixos-theme-toggle" aria-label="Toggle theme">
      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10.8 13.7A6.3 6.3 0 0 1 7.6 1.4a5.1 5.1 0 1 0 6.9 6.9 6.3 6.3 0 0 1-3.7 5.4Z"/></svg>
    </button>
    <div class="app-page">
      <div class="app-content">
        <div class="app-container">
          <div class="logo-box">
            <img class="logo-img" src="{{ pathjoin .ActionEndpoint "/assets/images/atomixos-logo.png" }}" alt="AtomixOS" />
            <h2 class="logo-txt">Sign In</h2>
          </div>

          {{ if eq .Data.login_options.authenticators_required "yes" }}
            <div id="authenticators" class="flex flex-col gap-2">
              {{ range .Data.login_options.authenticators }}
                <div>
                  <a class="atomixos-provider-entra" href="{{ if .endpoint }}{{ .endpoint }}{{ else }}#{{ end }}" {{ if not .endpoint }}onclick="showLoginForm('{{ .realm }}', '{{ .registration_enabled }}', '{{ .username_recovery_enabled }}', '{{ .contact_support_enabled }}', '{{ .ActionEndpoint }}');return false;"{{ end }}>
                    <div class="app-login-btn-box">
                      <div class="atomixos-provider-prefix"></div>
                      <div class="app-login-btn-txt">
                        <span class="leading-loose">Microsoft Entra</span>
                      </div>
                    </div>
                  </a>
                </div>
              {{ end }}
            </div>
          {{ end }}
        </div>
        <div id="bookmarks" class="px-4 hidden sm:block">
          <div onclick="showQRCode('{{ $qrCodeLink }}');return false;" class="bg-[#24292f] text-[#f6f8fa] py-1 px-1 shadow-xl rounded-b-lg pb-2 text-center" style="max-width: 3em;">
            <i class="las la-qrcode text-3xl"></i>
          </div>
        </div>
        <div id="qr" class="px-4 flex justify-center hidden">
          <div id="qrcode" onclick="hideQRCode();return false;" class="bg-white border border-t-2 py-1 px-1 shadow-xl rounded-b-lg pb-2 max-w-xs inline-flex"></div>
        </div>
      </div>
    </div>
    <script src="{{ pathjoin .ActionEndpoint "/assets/js/login.js" }}"></script>
    {{ if eq .Data.ui_options.custom_js_required "yes" }}
      <script src="{{ pathjoin .ActionEndpoint "/assets/js/custom.js" }}"></script>
    {{ end }}
  </body>
</html>
