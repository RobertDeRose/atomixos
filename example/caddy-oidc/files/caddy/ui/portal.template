<!DOCTYPE html>
<html lang="en" class="h-full bg-blue-100">
  <head>
    <title>{{ .MetaTitle }} - {{ .PageTitle }}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="{{ .MetaDescription }}" />
    <meta name="author" content="{{ .MetaAuthor }}" />
    <script>
      (function () {
        var match = document.cookie.match(/(?:^|;\s*)cockpit:theme=([^;]+)/);
        var theme = match && decodeURIComponent(match[1]);
        if (theme !== "light" && theme !== "dark") {
          theme = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
        document.documentElement.classList.add("pf-v6-theme-" + theme);
      })();
    </script>
    <link rel="shortcut icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/google-webfonts/roboto.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/line-awesome/line-awesome.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/portal.css" }}" />
    {{ if eq .Data.ui_options.custom_css_required "yes" }}
      <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/custom.css" }}" />
    {{ end }}
  </head>

  <body class="h-full">
    <button type="button" class="atomixos-theme-toggle" aria-label="Toggle theme">
      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10.8 13.7A6.3 6.3 0 0 1 7.6 1.4a5.1 5.1 0 1 0 6.9 6.9 6.3 6.3 0 0 1-3.7 5.4Z"/></svg>
    </button>
    <div class="app-page">
      <div class="app-content">
        <div class="app-container">
          <div class="logo-col-box justify-center">
            <div>
              <img class="logo-img" src="{{ pathjoin .ActionEndpoint "/assets/images/atomixos-logo.png" }}" alt="AtomixOS" />
            </div>
            <div>
              <h2 class="logo-col-txt">Applications</h2>
            </div>
          </div>
          <div class="mt-3 grid">
            {{ range .PrivateLinks }}
              <div class="pb-2">
                <a href="{{ .Link }}" {{ if .TargetEnabled }}target="{{ .Target }}"{{ end }}>
                  <div class="app-portal-btn-box">
                    <div class="app-portal-btn-img">{{ if .IconEnabled -}}<i class="{{ .IconName }}"></i>{{- end }}</div>
                    <div class="app-portal-btn-txt"><span>{{ .Title }}</span></div>
                  </div>
                </a>
              </div>
            {{ end }}
            <div class="pb-2">
              <a href="{{ pathjoin .ActionEndpoint "/logout" }}">
                <div class="app-portal-btn-box">
                  <div class="app-portal-btn-img"><i class="las la-sign-out-alt"></i></div>
                  <div class="app-portal-btn-txt"><span>{{ .Data.i18n_sign_out }}</span></div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="{{ pathjoin .ActionEndpoint "/assets/js/portal.js" }}"></script>
    {{ if eq .Data.ui_options.custom_js_required "yes" }}
      <script src="{{ pathjoin .ActionEndpoint "/assets/js/custom.js" }}"></script>
    {{ end }}
  </body>
</html>
