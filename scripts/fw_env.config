# U-Boot environment configuration for fw_setenv / fw_printenv
#
# Must match the compiled-in U-Boot config:
#   CONFIG_ENV_IS_IN_MMC=y
#   CONFIG_ENV_OFFSET=0x3F8000
#   CONFIG_ENV_SIZE=0x8000 (32 KiB, ARCH_ROCKCHIP default)
#   CONFIG_ENV_MMC_DEVICE_INDEX=1
#
# No redundant env — CONFIG_ENV_REDUNDANT is not set in the defconfig.
# Format: device  offset  size

/dev/mmcblk1    0x3F8000    0x8000
