# U-Boot environment configuration for fw_setenv / fw_printenv
# Redundant environment storage: two copies at different eMMC offsets
# for power-loss resilience.
#
# The U-Boot environment is stored on the eMMC at:
#   Primary:   offset 0x3F8000 (sector 8128, ~4MB - 32KB)
#   Redundant: offset 0x3FC000 (sector 8136, ~4MB - 16KB)
#
# These offsets are within the raw U-Boot region (0-4MB) but after
# the u-boot.itb image (which typically ends well before 4MB).

# Device path for the eMMC
/dev/mmcblk1    0x3F8000    0x4000
/dev/mmcblk1    0x3FC000    0x4000
